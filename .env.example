# Docker Compose already supplies these safe synthetic defaults.
NOURISHOPS_DATABASE_URL=postgresql://nourishops:nourishops@127.0.0.1:55432/nourishops
NOURISHOPS_ENV=development
NOURISHOPS_AGENT_MODE=offline
NOURISHOPS_AGENT_PROVIDER=anthropic
NOURISHOPS_AGENT_MODEL=claude-haiku-4-5
NOURISHOPS_AGENT_TIMEOUT_SECONDS=6
NOURISHOPS_AGENT_DEADLINE_SECONDS=12
NOURISHOPS_AGENT_MAX_RETRIES=1
NOURISHOPS_ALLOWED_ORIGIN=http://127.0.0.1:5173

# Add one provider key only to an uncommitted .env when using live mode.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
